.codex-remote-attachments/
Claude Design Audit Files/
rendered_docx/
rendered_pdf/

# Transient push payloads generated by the scheduled workflows.
# CI writes these, sends them, then deletes them before committing — they
# must never be tracked. (Ignored so a local `flight:update` / `reminder:update`
# run cannot accidentally stage them.)
data/flight-notifications.json
data/trip-push-notifications.json
notification-*.txt
trip-reminder-*.txt

# .claude/ holds machine-local Claude Code config. settings.local.json carries
# personal permission overrides and must stay untracked, but settings.json
# (the Drive-drift SessionStart hook) has no secrets and must be shared.
.claude/*
!.claude/settings.json
